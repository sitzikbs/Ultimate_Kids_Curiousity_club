# Ultimate Kids Curiosity Club - Environment Configuration Template
# Copy this file to .env and update with your actual values

# ============================================================================
# MOCK MODE
# ============================================================================
# Set to true for development (no API keys needed)
# Set to false for production (API keys required)
USE_MOCK_SERVICES=true

# ============================================================================
# API KEYS (required when USE_MOCK_SERVICES=false)
# ============================================================================
# OpenAI API Key for LLM and image generation
# OPENAI_API_KEY=sk-...

# Anthropic API Key for Claude LLM
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API Key for LLM
# GEMINI_API_KEY=...

# ElevenLabs API Key for text-to-speech
# ELEVENLABS_API_KEY=...

# ============================================================================
# PROVIDER PREFERENCES
# ============================================================================
# LLM Provider (openai, anthropic, gemini, gemma, mock)
LLM_PROVIDER=gemma

# TTS Provider (elevenlabs, google, openai, vibevoice, mock)
TTS_PROVIDER=vibevoice

# Which image generation provider to use (flux, dalle, mock)
IMAGE_PROVIDER=flux

# ============================================================================
# STORAGE PATHS (relative to project root)
# ============================================================================
# Base data directory
DATA_DIR=data

# Show blueprints directory
SHOWS_DIR=data/shows

# Episode data directory
EPISODES_DIR=data/episodes

# Static assets directory (images, etc.)
ASSETS_DIR=data/assets

# Generated audio files directory
AUDIO_OUTPUT_DIR=data/audio

# ============================================================================
# DOCKER INFRASTRUCTURE (used by docker-compose services)
# ============================================================================
# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kids-curiosity-club

# CDN
CDN_BASE_URL=https://cdn.kidscuriosityclub.com

# LLM Service (Docker)
LLM_MODEL=gemma4:26b-a4b
LLM_BASE_URL=http://llm:11435/v1

# TTS Service (Docker)
TTS_MODEL=vibevoice-1.5b
TTS_BASE_URL=http://tts:8100

# Distribution Service (Docker)
DISTRIBUTION_BASE_URL=http://distribution:8200
